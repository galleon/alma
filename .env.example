# Copy this file to .env and adjust as needed. No secrets are required to run the demo.
#
# This file is for the MANUAL (non-Docker) setup path only -- see README.md.
# `docker compose up` for the containerized app ignores these values on purpose
# (it hardcodes the in-network Neo4j URL and the host.docker.internal Ollama
# address in docker-compose.yml) so this host-oriented file can't silently
# break the container's networking.

# --- Neo4j (matches docker-compose.yml defaults) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

# --- LLM explainability layer ---
# Default: local Ollama, OpenAI-compatible endpoint, no API key needed.
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen3.5:9b
# Ollama ignores the API key value but the OpenAI SDK requires the field to be set.
LLM_API_KEY=ollama

# Optional: to use a real OpenAI-compatible API instead of Ollama, set:
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-...   (or export OPENAI_API_KEY instead)

# --- Synthetic data generation ---
DATA_SEED=42
